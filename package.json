{
	"name": "@altoviz/n8n-nodes-altoviz",
	"version": "0.1.0",
	"description": "n8n community node for the Altoviz app",
	"license": "MIT",
	"homepage": "https://altoviz.com",
	"keywords": [
		"n8n-community-node-package",
		"altoviz",
		"n8n",
		"invoicing"
	],
	"author": {
		"name": "adanvy",
		"email": "contact@altoviz.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/altoviz/n8n.git"
	},
	  "engines" : { 
    "npm" : ">=11",
    "node" : ">=22"
  },
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"dev:staging": "ALTOVIZ_API_BASE_URL=https://api.altoviz.xyz WEBHOOK_URL=https://gx5sjlq1-5678.uks1.devtunnels.ms n8n start",
		"dev:staging:watch": "n8n-node dev --external-n8n",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"start": "n8n start",
		"start:staging": "ALTOVIZ_API_BASE_URL=https://api.altoviz.xyz WEBHOOK_URL=https://gx5sjlq1-5678.uks1.devtunnels.ms n8n start"
	},
	"files": [
		"dist",
		"README.md"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AltovizApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Altoviz/Altoviz.node.js",
			"dist/nodes/AltovizTrigger/AltovizTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
